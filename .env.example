# -----------------------------------------------------------------------------
# RIGI RIGI ANIME Production Environment Variables Template
# Copy this file to '.env' and populate the actual values for production deploy.
# -----------------------------------------------------------------------------

# Application Environment Configuration
ENV=production
LOG_LEVEL=info
PORT=8000

# Security Credentials
# WARNING: Change this value to a strong random token on the live host
JWT_SECRET=supersecretproductionkeychangeit

# Database connection URL
# Format: postgresql://[user]:[password]@[host]:[port]/[database_name]
DATABASE_URL=postgresql://user:password@db:5432/rigirigianime


# Integration & Bridge Settings
MCP_REMOTE_BRIDGE=false
